// Sputnik Debug Build Configuration
//
// How to use:
//   1. Open Package.swift in Xcode
//   2. File → Project Settings (or Project → Info in older Xcode)
//   3. Debug → "Config"   (this file — Automatic signing, local dev)
//      Release → "Config.Release"  (separate file — Manual signing for distribution)
//   4. Build and run — entitlements will be applied automatically
//
// For distribution (ad-hoc / App Store / notarization):
//   - Set Release config to "Config.Release"
//   - Fill in your Team ID and provisioning profile in Config.Release.xcconfig

CODE_SIGN_ENTITLEMENTS = App-Sputnik/Sputnik.entitlements
CODE_SIGN_STYLE = Automatic

// Hardened Runtime is required for notarization (Developer ID distribution).
// It is NOT the App Sandbox — it does not restrict filesystem access, so the
// embedded terminal keeps full system reach. No cs.* exception entitlements
// are needed: Sputnik only spawns Apple-signed /bin/zsh and uses no JIT.
ENABLE_HARDENED_RUNTIME = YES
MACOSX_DEPLOYMENT_TARGET = 14.0
PRODUCT_BUNDLE_IDENTIFIER = com.lukeisham.sputnik
INFOPLIST_FILE = App-Sputnik/Info.plist
