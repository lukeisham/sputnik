// Release build settings for the Sputnik macOS app target.
SWIFT_VERSION = 6.0
SWIFT_STRICT_CONCURRENCY = complete
MACOSX_DEPLOYMENT_TARGET = 26.0
CODE_SIGN_STYLE = Automatic
PRODUCT_NAME = Sputnik
PRODUCT_BUNDLE_IDENTIFIER = com.example.App-Sputnik
INFOPLIST_FILE = App-Sputnik/Info.plist
CODE_SIGN_ENTITLEMENTS = App-Sputnik/App-Sputnik.entitlements
ENABLE_HARDENED_RUNTIME = YES
SWIFT_OPTIMIZATION_LEVEL = -O
SWIFT_COMPILATION_MODE = wholemodule
